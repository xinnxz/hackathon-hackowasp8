{
  "policy": {
    "failOn": ["high", "critical"],
    "scoreThreshold": 0
  },
  "ignore": {
    "paths": [
      "node_modules/**",
      "dist/**",
      "report/**",
      "docs/**",
      "demo/**",
      "tests/**"
    ],
    "findings": []
  },
  "report": {
    "outputDir": "./report"
  }
}
