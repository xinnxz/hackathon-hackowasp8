{
  "policy": {
    "failOn": ["high", "critical"],
    "scoreThreshold": 0
  },
  "rules": {
    "cors": true,
    "injection": true,
    "authMiddleware": true,
    "xss": true,
    "eval": true,
    "ssrf": true,
    "insecureHttp": false,
    "weakCrypto": true,
    "pathTraversal": true
  },
  "ignore": {
    "paths": [
      "node_modules/**",
      "dist/**",
      "report/**",
      "report-demo-*/**",
      "docs/**",
      "demo/**",
      "tests/**",
      "src/dashboard/**"
    ],
    "findings": []
  },
  "report": {
    "outputDir": "./report"
  }
}
