{
  "policy": {
    "failOn": ["high", "critical"],
    "scoreThreshold": 0
  },
  "rules": {
    "secrets": true,
    "injection": true,
    "xss": true,
    "cors": true,
    "eval": true,
    "ssrf": true,
    "weakCrypto": true,
    "pathTraversal": true,
    "insecureHttp": true,
    "authMiddleware": true,
    "dependencies": true
  },
  "ignore": {
    "paths": [],
    "findings": []
  },
  "ai": {
    "enabled": true,
    "model": "llama-3.3-70b-versatile (Groq)"
  },
  "report": {
    "formats": ["json", "html", "sarif", "markdown"],
    "outputDir": "./report"
  }
}
