{
  "name": "owasp-guardrail",
  "version": "2.0.0",
  "description": "OWASP Guardrail — Zero-dependency DevSecOps scanner with OWASP Top 10 mapping, A+ to F grading, and Groq LLaMA 3.3 AI auto-remediation",
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "guardrail": "tsx src/cli.ts",
    "scan:demo": "tsx src/cli.ts scan demo/vulnerable-app",
    "scan:fixed": "tsx src/cli.ts scan demo/fixed-app",
    "scan:demo:ai": "tsx src/cli.ts scan demo/vulnerable-app --with-ai",
    "scan:fixed:ai": "tsx src/cli.ts scan demo/fixed-app --with-ai",
    "dashboard": "tsx src/cli.ts dashboard",
    "test": "tsx --test tests/**/*.test.ts",
    "demo:judge": "npm run build && node --no-warnings scripts/judge-demo.mjs",
    "demo:judge:ai": "npm run build && node --no-warnings scripts/judge-demo.mjs --with-ai"
  },
  "keywords": [
    "owasp",
    "security",
    "scanner",
    "sast",
    "devsecops",
    "vulnerability",
    "ai",
    "groq",
    "llama",
    "sarif",
    "ci-cd",
    "hackowasp"
  ],
  "author": "xinnxz",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/xinnxz/hackowasp8.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
