# ════════════════════════════════════════════════════════════
# ⛨  OWASP Guardrail — Environment Configuration
# ════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control.
#            The .gitignore already excludes it.
# ════════════════════════════════════════════════════════════

# ── AI Remediation Engine ──────────────────────────────────
# Required for --with-ai flag (AI auto-fix suggestions).
# Get your free API key at: https://console.groq.com/keys
# Model used: LLaMA 3.3-70B Versatile
# Free tier: 30 requests/min, 14,400 requests/day
GROQ_API_KEY=

# ── Legacy Fallback (Optional) ─────────────────────────────
# If GROQ_API_KEY is not set, the system checks this as
# a fallback. You do NOT need both — just set GROQ_API_KEY.
GEMINI_API_KEY=

# ── Dashboard Configuration (Optional) ─────────────────────
# Default port for the live dashboard server
# DASHBOARD_PORT=4000

# ── Scan Configuration (Optional) ──────────────────────────
# Override the default output directory for reports
# REPORT_OUTPUT_DIR=./report
